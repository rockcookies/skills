{
  "search.exclude": {
    "sources/**": true,
    "vendor/**": true,
    "upstream/**": true
  },
  "prettier.enable": false,
  "editor.formatOnSave": false,
  "eslint.enable": false,
  "oxc.enable": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit",
    "source.organizeImports": "never"
  },
  "vsicons.presets.nestjs": true
}
